  {
    "id": "parallax-scroll",
    "title": "视差滚动",
    "description": "多层背景以不同速度滚动产生视差",
    "category": "animation",
    "tags": ["视差", "滚动", "背景"],
    "html": "<div class=\"parallax\"><div class=\"layer layer1\"></div><div class=\"layer layer2\"></div><div class=\"layer layer3\"></div><div class=\"content\">滚动查看效果</div></div>",
    "css": "body{margin:0;height:200vh;background:#0d0d0d}.parallax{position:relative;height:100vh;overflow:hidden}.layer{position:absolute;width:120%;height:120%;left:-10%;top:-10%}.layer1{background:linear-gradient(180deg,#1a1a2e 0%,#16213e 100%);transform:translateZ(-2px) scale(3)}.layer2{background:radial-gradient(circle at 30% 30%,rgba(102,126,234,0.3) 0%,transparent 50%);transform:translateZ(-1px) scale(2)}.layer3{background:radial-gradient(circle at 70% 70%,rgba(245,87,108,0.3) 0%,transparent 50%)}.content{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:#fff;font-size:3rem;font-family:sans-serif;text-align:center}",
    "js": "window.addEventListener('scroll',()=>{const scrolled=window.pageYOffset;document.querySelectorAll('.layer').forEach((layer,i)=>{const speed=(i+1)*0.5;layer.style.transform='translateY('+scrolled*speed+'px)'})})",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "countdown-timer",
    "title": "倒计时器",
    "description": "带翻页效果的倒计时组件",
    "category": "ui",
    "tags": ["倒计时", "计时器", "组件"],
    "html": "<div class=\"countdown\"><div class=\"unit\"><span id=\"h\">00</span><label>时</label></div><div class=\"unit\"><span id=\"m\">00</span><label>分</label></div><div class=\"unit\"><span id=\"s\">00</span><label>秒</label></div></div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.countdown{display:flex;gap:20px}.unit{text-align:center;background:#1a1a2e;padding:30px 40px;border-radius:16px;min-width:100px}.unit span{display:block;font-size:4rem;font-weight:bold;color:#667eea;font-variant-numeric:tabular-nums}.unit label{display:block;margin-top:10px;color:#888;font-size:1rem}",
    "js": "function update(){const now=new Date();const end=new Date(now.getFullYear(),now.getMonth(),now.getDate()+1);const diff=end-now;const h=Math.floor(diff/3600000);const m=Math.floor((diff%3600000)/60000);const s=Math.floor((diff%60000)/1000);document.getElementById('h').textContent=String(h).padStart(2,'0');document.getElementById('m').textContent=String(m).padStart(2,'0');document.getElementById('s').textContent=String(s).padStart(2,'0')};setInterval(update,1000);update()",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "image-comparison",
    "title": "图片对比",
    "description": "拖拽滑块对比两张图片",
    "category": "ui",
    "tags": ["图片", "对比", "滑块"],
    "html": "<div class=\"compare\" id=\"compare\"><div class=\"before\"></div><div class=\"after\"></div><div class=\"slider\"></div></div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center}.compare{position:relative;width:600px;height:400px;overflow:hidden;border-radius:12px;cursor:ew-resize}.before,.after{position:absolute;inset:0}.before{background:linear-gradient(135deg,#667eea,#764ba2)}.after{background:linear-gradient(135deg,#f093fb,#f5576c);width:50%}.slider{position:absolute;top:0;bottom:0;left:50%;width:4px;background:#fff;transform:translateX(-50%);box-shadow:0 0 10px rgba(0,0,0,0.5)}",
    "js": "const c=document.getElementById('compare'),after=c.querySelector('.after'),slider=c.querySelector('.slider');let isDragging=false;c.addEventListener('mousedown',()=>isDragging=true);window.addEventListener('mouseup',()=>isDragging=false);c.addEventListener('mousemove',e=>{if(!isDragging)return;const rect=c.getBoundingClientRect();const x=Math.max(0,Math.min(1,(e.clientX-rect.left)/rect.width));after.style.width=x*100+'%';slider.style.left=x*100+'%'})",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  }
]