  {
    "id": "scroll-reveal",
    "title": "滚动显示",
    "description": "元素随滚动逐渐显示动画",
    "category": "animation",
    "tags": ["滚动", "显示", "动画"],
    "html": "<div class=\"container\"><div class=\"box\">向下滚动</div><div class=\"box reveal\">我会淡入</div><div class=\"box reveal\">我也会</div><div class=\"box reveal\">还有我</div></div>",
    "css": "body{margin:0;background:#0d0d0d;font-family:sans-serif}.container{padding:100px 20px;max-width:600px;margin:0 auto}.box{padding:60px;margin:40px 0;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:16px;color:#fff;text-align:center;font-size:1.5rem;opacity:0;transform:translateY(50px);transition:all 0.6s ease}.box.visible{opacity:1;transform:translateY(0)}",
    "js": "const boxes=document.querySelectorAll('.reveal');const observer=new IntersectionObserver((entries)=>{entries.forEach(entry=>{if(entry.isIntersecting)entry.target.classList.add('visible')})},{threshold:0.3});boxes.forEach(box=>observer.observe(box))",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
