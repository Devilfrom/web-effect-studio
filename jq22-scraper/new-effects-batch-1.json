[
  {
    "id": "particle-network",
    "title": "粒子连线网络",
    "description": "Canvas 粒子之间自动连线，鼠标靠近产生互动",
    "category": "animation",
    "tags": ["粒子", "Canvas", "连线", "互动"],
    "html": "<canvas id=\"c\"></canvas>",
    "css": "body{margin:0;overflow:hidden;background:#0a0a0a}canvas{position:fixed;top:0;left:0}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');let w,h,p=[],m={x:null,y:null};function resize(){w=c.width=window.innerWidth;h=c.height=window.innerHeight}function create(){return{x:Math.random()*w,y:Math.random()*h,vx:(Math.random()-0.5)*2,vy:(Math.random()-0.5)*2,size:Math.random()*2+1}};for(let i=0;i<80;i++)p.push(create());function draw(){x.fillStyle='rgba(10,10,10,0.1)';x.fillRect(0,0,w,h);p.forEach((a,i)=>{a.x+=a.vx;a.y+=a.vy;if(a.x<0||a.x>w)a.vx*=-1;if(a.y<0||a.y>h)a.vy*=-1;x.fillStyle='rgba(100,200,255,0.6)';x.beginPath();x.arc(a.x,a.y,a.size,0,Math.PI*2);x.fill();p.slice(i+1).forEach(b=>{const dx=a.x-b.x,dy=a.y-b.y,d=Math.sqrt(dx*dx+dy*dy);if(d<150){x.strokeStyle='rgba(100,200,255,'+(1-d/150)*0.3+')';x.lineWidth=1;x.beginPath();x.moveTo(a.x,a.y);x.lineTo(b.x,b.y);x.stroke()}});if(m.x){const dx=a.x-m.x,dy=a.y-m.y,d=Math.sqrt(dx*dx+dy*dy);if(d<200){x.strokeStyle='rgba(255,100,100,'+(1-d/200)*0.5+')';x.beginPath();x.moveTo(a.x,a.y);x.lineTo(m.x,m.y);x.stroke()}}});requestAnimationFrame(draw)}window.addEventListener('resize',resize);window.addEventListener('mousemove',e=>{m.x=e.clientX;m.y=e.clientY});window.addEventListener('mouseout',()=>{m.x=m.y=null});resize();draw()",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "wave-text",
    "title": "波浪文字",
