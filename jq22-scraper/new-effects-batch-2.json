    "tags": ["滚动", "无限", "列表"],
    "html": "<div class=\"scroll-container\"><div class=\"scroll-content\"><div class=\"item\">Item 1</div><div class=\"item\">Item 2</div><div class=\"item\">Item 3</div><div class=\"item\">Item 4</div></div></div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.scroll-container{width:300px;height:400px;overflow:hidden;border-radius:12px;background:#1a1a2e}.scroll-content{animation:scroll 8s linear infinite}.item{padding:30px;text-align:center;color:#fff;border-bottom:1px solid #333;font-size:1.2rem}@keyframes scroll{0%{transform:translateY(0)}100%{transform:translateY(-50%)}}",
    "js": "const content=document.querySelector('.scroll-content');content.innerHTML+=content.innerHTML",
    "authorName": "Web Effect Studio",
