[
  {
    "id": "audio-visualizer",
    "title": "音频可视化",
    "description": "Canvas 音频频谱可视化效果",
    "category": "animation",
    "tags": ["音频", "可视化", "Canvas"],
    "html": "<canvas id=\"c\"></canvas><p>点击开始模拟</p>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:sans-serif;color:#888}canvas{border-radius:12px}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');c.width=600;c.height=200;let bars=Array(64).fill(0),t=0;function animate(){x.fillStyle='#0d0d0d';x.fillRect(0,0,c.width,c.height);bars=bars.map((v,i)=>{const target=Math.random()*150+20;return v+(target-v)*0.1});const bw=c.width/bars.length;bars.forEach((h,i)=>{const hue=(i/bars.length)*360;x.fillStyle='hsl('+hue+',70%,50%)';x.fillRect(i*bw,c.height-h,bw-2,h)});requestAnimationFrame(animate)}document.addEventListener('click',animate);animate()",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "magnetic-button",
    "title": "磁性按钮",
    "description": "按钮被鼠标吸引的磁性效果",
    "category": "ui",
    "tags": ["按钮", "磁性", "互动"],
    "html": "<button class=\"magnetic\">磁性按钮</button>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.magnetic{padding:24px 48px;font-size:1.2rem;color:#fff;background:#667eea;border:none;border-radius:12px;cursor:pointer;transition:transform 0.2s ease}",
    "js": "const btn=document.querySelector('.magnetic');document.addEventListener('mousemove',e=>{const rect=btn.getBoundingClientRect();const x=e.clientX-(rect.left+rect.width/2);const y=e.clientY-(rect.top+rect.height/2);const dist=Math.sqrt(x*x+y*y);if(dist<150){const strength=(150-dist)/150;btn.style.transform='translate('+x*strength*0.3+'px,'+y*strength*0.3+'px)'}else{btn.style.transform='translate(0,0)'}})",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "text-scramble",
    "title": "文字打乱",
    "description": "文字随机打乱后重组的特效",
    "category": "text",
    "tags": ["文字", "打乱", "动画"],
    "html": "<div class=\"text\" data-value=\"HELLO WORLD\">HELLO WORLD</div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:monospace}.text{font-size:3rem;color:#0f0;cursor:pointer}",
    "js": "const el=document.querySelector('.text');const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';let interval=null;el.addEventListener('mouseenter',()=>{let iteration=0;clearInterval(interval);interval=setInterval(()=>{el.innerText=el.dataset.value.split('').map((letter,index)=>{if(index<iteration)return el.dataset.value[index];return chars[Math.floor(Math.random()*chars.length)]}).join('');if(iteration>=el.dataset.value.length)clearInterval(interval);iteration+=1/3},30)})",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "fireworks-canvas",
    "title": "烟花效果",
    "description": "Canvas 烟花绽放动画",
    "category": "animation",
    "tags": ["烟花", "Canvas", "粒子"],
    "html": "<canvas id=\"c\"></canvas><p>点击发射烟花</p>",
    "css": "body{margin:0;min-height:100vh;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:sans-serif;color:#888}canvas{position:fixed;top:0;left:0}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');c.width=window.innerWidth;c.height=window.innerHeight;let fireworks=[],particles=[];class Firework{constructor(tx,ty){this.x=c.width/2;this.y=c.height;this.tx=tx;this.ty=ty;this.speed=3;this.angle=Math.atan2(ty-c.height,tx-c.width/2);this.vx=Math.cos(this.angle)*this.speed;this.vy=Math.sin(this.angle)*this.speed;this.hue=Math.random()*360}update(){this.x+=this.vx;this.y+=this.vy;if(Math.abs(this.x-this.tx)<10&&Math.abs(this.y-this.ty)<10){for(let i=0;i<50;i++)particles.push(new Particle(this.x,this.y,this.hue));return true}return false}draw(){x.fillStyle='hsl('+this.hue+',100%,50%)';x.beginPath();x.arc(this.x,this.y,3,0,Math.PI*2);x.fill()}}class Particle{constructor(x,y,hue){this.x=x;this.y=y;this.hue=hue;this.angle=Math.random()*Math.PI*2;this.speed=Math.random()*5+2;this.vx=Math.cos(this.angle)*this.speed;this.vy=Math.sin(this.angle)*this.speed;this.alpha=1;this.decay=Math.random()*0.02+0.01}update(){this.x+=this.vx;this.y+=this.vy;this.vy+=0.1;this.alpha-=this.decay;return this.alpha<=0}draw(){x.fillStyle='hsla('+this.hue+',100%,50%,'+this.alpha+')';x.beginPath();x.arc(this.x,this.y,2,0,Math.PI*2);x.fill()}}function animate(){x.fillStyle='rgba(0,0,0,0.1)';x.fillRect(0,0,c.width,c.height);fireworks=fireworks.filter(fw=>{fw.draw();return !fw.update()});particles=particles.filter(p=>{p.draw();return !p.update()});requestAnimationFrame(animate)}c.addEventListener('click',e=>fireworks.push(new Firework(e.clientX,e.clientY)));animate()",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "infinite-scroll",
    "title": "无限滚动",
    "description": "无缝循环滚动的内容列表",
