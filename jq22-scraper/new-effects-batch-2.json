  {
    "id": "spotlight-effect",
    "title": "聚光灯效果",
    "description": "鼠标移动产生聚光灯照明效果",
    "category": "animation",
    "tags": ["聚光灯", "鼠标", "效果"],
    "html": "<div class=\"spotlight\"><h1>聚光灯效果</h1><p>移动鼠标查看效果</p></div>",
    "css": "body{margin:0;min-height:100vh;background:#000;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.spotlight{position:relative;padding:100px;text-align:center;color:#fff;background:radial-gradient(circle at var(--x,50%) var(--y,50%),transparent 0%,rgba(0,0,0,0.95) 200px)}.spotlight h1{font-size:3rem;margin:0 0 20px}.spotlight p{color:#888}",
    "js": "const spot=document.querySelector('.spotlight');document.addEventListener('mousemove',e=>{const rect=spot.getBoundingClientRect();const x=((e.clientX-rect.left)/rect.width)*100;const y=((e.clientY-rect.top)/rect.height)*100;spot.style.setProperty('--x',x+'%');spot.style.setProperty('--y',y+'%')})",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "drag-drop-list",
    "title": "拖拽排序",
    "description": "可拖拽排序的列表组件",
    "category": "ui",
    "tags": ["拖拽", "排序", "列表"],
    "html": "<ul class=\"sortable\"><li draggable=\"true\">项目 1</li><li draggable=\"true\">项目 2</li><li draggable=\"true\">项目 3</li><li draggable=\"true\">项目 4</li></ul>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.sortable{list-style:none;padding:0;margin:0;width:300px}.sortable li{padding:20px;margin:10px 0;background:#1a1a2e;border-radius:8px;color:#fff;cursor:move;transition:all 0.2s}.sortable li.dragging{opacity:0.5;transform:scale(1.02)}.sortable li.over{border:2px dashed #667eea}",
    "js": "const list=document.querySelector('.sortable');let dragged=null;list.addEventListener('dragstart',e=>{dragged=e.target;e.target.classList.add('dragging')});list.addEventListener('dragend',e=>e.target.classList.remove('dragging'));list.addEventListener('dragover',e=>{e.preventDefault();const after=getAfter(list,e.clientY);if(after)list.insertBefore(dragged,after);else list.appendChild(dragged)});function getAfter(container,y){return [...container.querySelectorAll('li:not(.dragging)')].reduce((closest,child)=>{const box=child.getBoundingClientRect();const offset=y-box.top-box.height/2;if(offset<0&&offset>closest.offset)return{offset,element:child};return closest},{offset:Number.NEGATIVE_INFINITY}).element}",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "circular-menu",
    "title": "圆形菜单",
    "description": "点击展开圆形分布的菜单项",
    "category": "ui",
    "tags": ["菜单", "圆形", "展开"],
    "html": "<div class=\"menu\"><button class=\"toggle\">+</button><div class=\"items\"><span>🏠</span><span>🔍</span><span>⚙️</span><span>👤</span></div></div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.menu{position:relative;width:60px;height:60px}.toggle{width:60px;height:60px;border-radius:50%;border:none;background:#667eea;color:#fff;font-size:2rem;cursor:pointer;transition:transform 0.3s;z-index:10;position:relative}.menu.active .toggle{transform:rotate(45deg)}.items{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}.items span{position:absolute;width:50px;height:50px;border-radius:50%;background:#1a1a2e;display:flex;align-items:center;justify-content:center;font-size:1.5rem;cursor:pointer;transition:all 0.3s;opacity:0}.menu.active .items span:nth-child(1){transform:translate(-80px,0);opacity:1}.menu.active .items span:nth-child(2){transform:translate(0,-80px);opacity:1}.menu.active .items span:nth-child(3){transform:translate(80px,0);opacity:1}.menu.active .items span:nth-child(4){transform:translate(0,80px);opacity:1}",
    "js": "document.querySelector('.toggle').addEventListener('click',()=>document.querySelector('.menu').classList.toggle('active'))",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
