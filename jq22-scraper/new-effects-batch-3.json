[
  {
    "id": "clock-analog",
    "title": "模拟时钟",
    "description": "Canvas 绘制的模拟时钟，实时显示当前时间",
    "category": "ui",
    "tags": ["时钟", "Canvas", "实时"],
    "html": "<canvas id=\"clock\" width=\"300\" height=\"300\"></canvas>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center}canvas{background:#1a1a2e;border-radius:50%;box-shadow:0 0 50px rgba(102,126,234,0.3)}",
    "js": "const c=document.getElementById('clock'),x=c.getContext('2d'),r=150;function draw(){x.clearRect(0,0,300,300);const now=new Date(),h=now.getHours(),m=now.getMinutes(),s=now.getSeconds();x.strokeStyle='#667eea';x.lineWidth=2;x.beginPath();x.arc(r,r,140,0,Math.PI*2);x.stroke();for(let i=0;i<12;i++){const a=(i*30-90)*Math.PI/180;x.beginPath();x.moveTo(r+120*Math.cos(a),r+120*Math.sin(a));x.lineTo(r+135*Math.cos(a),r+135*Math.sin(a));x.stroke()}x.lineWidth=4;x.strokeStyle='#fff';const ha=((h%12)*30+m*0.5-90)*Math.PI/180;x.beginPath();x.moveTo(r,r);x.lineTo(r+80*Math.cos(ha),r+80*Math.sin(ha));x.stroke();x.lineWidth=3;const ma=(m*6-90)*Math.PI/180;x.beginPath();x.moveTo(r,r);x.lineTo(r+110*Math.cos(ma),r+110*Math.sin(ma));x.stroke();x.strokeStyle='#f5576c';x.lineWidth=2;const sa=(s*6-90)*Math.PI/180;x.beginPath();x.moveTo(r,r);x.lineTo(r+130*Math.cos(sa),r+130*Math.sin(sa));x.stroke();requestAnimationFrame(draw)}draw()",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "matrix-rain",
    "title": "矩阵雨",
    "description": "黑客帝国风格的矩阵代码雨效果",
    "category": "animation",
    "tags": ["矩阵", "代码雨", "黑客帝国"],
    "html": "<canvas id=\"c\"></canvas>",
    "css": "body{margin:0;overflow:hidden;background:#000}canvas{position:fixed;top:0;left:0}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');c.width=window.innerWidth;c.height=window.innerHeight;const chars='ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*',fontSize=14,columns=c.width/fontSize,drops=[];for(let i=0;i<columns;i++)drops[i]=Math.random()*-100;x.fillStyle='#0f0';x.font=fontSize+'px monospace';function draw(){x.fillStyle='rgba(0,0,0,0.05)';x.fillRect(0,0,c.width,c.height);x.fillStyle='#0f0';for(let i=0;i<drops.length;i++){const text=chars[Math.floor(Math.random()*chars.length)];x.fillText(text,i*fontSize,drops[i]*fontSize);if(drops[i]*fontSize>c.height&&Math.random()>0.975)drops[i]=0;drops[i]++}requestAnimationFrame(draw)}draw()",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "gradient-border-card",
    "title": "渐变边框卡片",
    "description": "动态渐变边框的卡片效果",
    "category": "ui",
    "tags": ["渐变", "边框", "卡片"],
    "html": "<div class=\"card\"><h2>渐变边框</h2><p>这是一个带有动态渐变边框的卡片效果。</p></div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.card{position:relative;width:300px;padding:30px;background:#1a1a2e;border-radius:16px;color:#fff;z-index:1}.card::before{content:'';position:absolute;inset:-2px;background:linear-gradient(45deg,#667eea,#764ba2,#f093fb,#f5576c);border-radius:18px;z-index:-1;animation:rotate 3s linear infinite;background-size:400% 400%}.card::after{content:'';position:absolute;inset:0;background:#1a1a2e;border-radius:16px;z-index:-1}@keyframes rotate{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}h2{margin:0 0 15px}p{color:#aaa;margin:0;line-height:1.6}",
    "js": "",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
