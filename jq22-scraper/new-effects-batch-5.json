    "html": "<div id=\"wave\"></div><div id=\"content\">Gradient Wave</div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif;overflow:hidden}#wave{position:absolute;inset:0;background:linear-gradient(45deg,#667eea,#764ba2,#f093fb,#f5576c);background-size:400%400%;animation:gradient 15s ease infinite}@keyframes gradient{0%{background-position:0%50%}50%{background-position:100%50%}100%{background-position:0%50%}}#content{position:relative;z-index:10;color:#fff;font-size:4rem;font-weight:bold;text-shadow:0 4px 20px rgba(0,0,0,0.3)}",
