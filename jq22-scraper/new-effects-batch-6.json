[
  {
    "id": "orbit-planets",
    "title": "行星轨道",
    "description": "太阳系行星公转动画",
    "category": "animation",
    "tags": ["行星", "轨道", "太空"],
    "html": "<canvas id=\"c\"></canvas>",
    "css": "body{margin:0;background:#000;display:flex;align-items:center;justify-content:center;min-height:100vh}canvas{display:block}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');c.width=800;c.height=600;const sun={x:400,y:300,r:40,color:'#FDB813'};const planets=[{r:15,dist:80,speed:0.02,color:'#A0522D'},{r:20,dist:130,speed:0.015,color:'#4169E1'},{r:18,dist:180,speed:0.01,color:'#FF6347'},{r:12,dist:240,speed:0.008,color:'#FF4500'},{r:35,dist:320,speed:0.004,color:'#DAA520'},{r:30,dist:400,speed:0.003,color:'#F4A460'}];let angle=0;function draw(){x.fillStyle='rgba(0,0,0,0.1)';x.fillRect(0,0,c.width,c.height);x.fillStyle=sun.color;x.beginPath();x.arc(sun.x,sun.y,sun.r,0,Math.PI*2);x.fill();x.shadowBlur=50;x.shadowColor=sun.color;x.fill();x.shadowBlur=0;planets.forEach(p=>{const px=sun.x+Math.cos(angle*p.speed)*p.dist;const py=sun.y+Math.sin(angle*p.speed)*p.dist;x.strokeStyle='rgba(255,255,255,0.1)';x.beginPath();x.arc(sun.x,sun.y,p.dist,0,Math.PI*2);x.stroke();x.fillStyle=p.color;x.beginPath();x.arc(px,py,p.r,0,Math.PI*2);x.fill()});angle+=0.01;requestAnimationFrame(draw)}draw();",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "pendulum-wave",
    "title": "摆波",
    "description": "多个摆锤形成的波浪图案",
    "category": "animation",
    "tags": ["摆锤", "波浪", "物理"],
    "html": "<canvas id=\"c\"></canvas>",
    "css": "body{margin:0;background:#0d0d0d;display:flex;align-items:center;justify-content:center;min-height:100vh}canvas{display:block}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');c.width=800;c.height=600;const pendulums=[];for(let i=0;i<15;i++){pendulums.push({length:100+i*20,angle:Math.PI/4,velocity:0})}const gravity=0.3;function draw(){x.fillStyle='rgba(13,13,13,0.2)';x.fillRect(0,0,c.width,c.height);const startX=c.width/2-280;pendulums.forEach((p,i)=>{const force=-gravity*Math.sin(p.angle)/p.length*100;p.velocity+=force;p.velocity*=0.99;p.angle+=p.velocity;const x1=startX+i*40;const y1=50;const x2=x1+Math.sin(p.angle)*p.length;const y2=y1+Math.cos(p.angle)*p.length;x.strokeStyle='rgba(102,126,234,0.5)';x.lineWidth=2;x.beginPath();x.moveTo(x1,y1);x.lineTo(x2,y2);x.stroke();x.fillStyle='#667eea';x.beginPath();x.arc(x2,y2,12,0,Math.PI*2);x.fill()});requestAnimationFrame(draw)}draw();",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
