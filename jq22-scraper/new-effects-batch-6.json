  {
    "id": "ripple-grid",
    "title": "网格涟漪",
    "description": "点击产生涟漪扩散的网格效果",
    "category": "animation",
    "tags": ["涟漪", "网格", "扩散"],
    "html": "<canvas id=\"c\"></canvas>",
    "css": "body{margin:0;background:#0d0d0d;display:flex;align-items:center;justify-content:center;min-height:100vh}canvas{display:block}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');c.width=window.innerWidth;c.height=window.innerHeight;const gridSize=40;let ripples=[];function draw(){x.fillStyle='#0d0d0d';x.fillRect(0,0,c.width,c.height);for(let x1=0;x1<c.width;x1+=gridSize){for(let y1=0;y1<c.height;y1+=gridSize){let offset=0;ripples.forEach(r=>{const dist=Math.sqrt((x1-r.x)**2+(y1-r.y)**2);if(dist<r.radius&&dist>r.radius-50){offset=(1-(r.radius-dist)/50)*20}});x.fillStyle='#1a1a2e';x.fillRect(x1,y1+offset,gridSize-2,gridSize-2)}}ripples.forEach((r,i)=>{r.radius+=5;if(r.radius>Math.max(c.width,c.height))ripples.splice(i,1)});requestAnimationFrame(draw)}c.addEventListener('click',e=>ripples.push({x:e.clientX,y:e.clientY,radius:0}));draw();",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "sine-wave",
    "title": "正弦波浪",
    "description": "动态正弦波浪动画",
    "category": "animation",
    "tags": ["正弦", "波浪", "数学"],
    "html": "<canvas id=\"c\"></canvas>",
    "css": "body{margin:0;background:#0d0d0d;display:flex;align-items:center;justify-content:center;min-height:100vh}canvas{display:block}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');c.width=800;c.height=400;let offset=0;function draw(){x.fillStyle='rgba(13,13,13,0.1)';x.fillRect(0,0,c.width,c.height);x.beginPath();x.strokeStyle='#667eea';x.lineWidth=3;for(let i=0;i<c.width;i++){const y=c.height/2+Math.sin((i+offset)*0.02)*100;x.lineTo(i,y)}x.stroke();offset+=2;requestAnimationFrame(draw)}draw();",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "spiral-galaxy",
    "title": "螺旋星系",
    "description": "旋转的螺旋星系粒子效果",
    "category": "animation",
    "tags": ["星系", "螺旋", "粒子"],
    "html": "<canvas id=\"c\"></canvas>",
    "css": "body{margin:0;background:#000;display:flex;align-items:center;justify-content:center;min-height:100vh}canvas{display:block}",
    "js": "const c=document.getElementById('c'),x=c.getContext('2d');c.width=800;c.height=800;const stars=[];for(let i=0;i<1000;i++){const angle=Math.random()*Math.PI*2;const radius=Math.random()*300;stars.push({angle,radius,speed:0.001+Math.random()*0.002,size:Math.random()*2,color:`hsl(${Math.random()*60+200},70%,${50+Math.random()*50}%)`})}function draw(){x.fillStyle='rgba(0,0,0,0.05)';x.fillRect(0,0,c.width,c.height);const cx=c.width/2,cy=c.height/2;x.fillStyle='#FDB813';x.beginPath();x.arc(cx,cy,30,0,Math.PI*2);x.fill();stars.forEach(s=>{s.angle+=s.speed;s.radius*=0.9999;if(s.radius<10)s.radius=300;const px=cx+Math.cos(s.angle)*s.radius;const py=cy+Math.sin(s.angle)*s.radius;x.fillStyle=s.color;x.beginPath();x.arc(px,py,s.size,0,Math.PI*2);x.fill()});requestAnimationFrame(draw)}draw();",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "stacked-cards",
    "title": "堆叠卡片",
    "description": "可切换的堆叠卡片展示",
    "category": "ui",
    "tags": ["卡片", "堆叠", "切换"],
    "html": "<div id=\"stack\"><div class=\"card\" style=\"background:#667eea\">卡片 1</div><div class=\"card\" style=\"background:#764ba2\">卡片 2</div><div class=\"card\" style=\"background:#f093fb\">卡片 3</div><div class=\"card\" style=\"background:#f5576c\">卡片 4</div></div><button id=\"next\">下一张</button>",
    "css": "body{margin:0;background:#0d0d0d;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif}#stack{position:relative;width:300px;height:200px}#stack .card{position:absolute;width:100%;height:100%;border-radius:16px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:2rem;font-weight:bold;box-shadow:0 10px 30px rgba(0,0,0,0.3);transition:all 0.3s;cursor:pointer}#stack .card:nth-child(1){z-index:4;transform:translateY(0)scale(1)}#stack .card:nth-child(2){z-index:3;transform:translateY(15px)scale(0.95)}#stack .card:nth-child(3){z-index:2;transform:translateY(30px)scale(0.9)}#stack .card:nth-child(4){z-index:1;transform:translateY(45px)scale(0.85)}button{margin-top:80px;padding:12px 30px;background:#667eea;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:1rem}",
    "js": "const stack=document.getElementById('stack');document.getElementById('next').onclick=()=>{const cards=stack.querySelectorAll('.card');const first=cards[0];first.style.transform='translateX(-120%)rotate(-10deg)';first.style.opacity='0';setTimeout(()=>{first.style.transition='none';first.style.transform='translateY(45px)scale(0.85)';first.style.opacity='1';stack.appendChild(first);setTimeout(()=>first.style.transition='all 0.3s',50)},300)};",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "timeline-vertical",
    "title": "垂直时间线",
    "description": "带动画的垂直时间线组件",
    "category": "ui",
    "tags": ["时间线", "垂直", "组件"],
    "html": "<div id=\"timeline\"><div class=\"item\"><div class=\"dot\"></div><div class=\"content\"><h3>2024</h3><p>项目启动</p></div></div><div class=\"item\"><div class=\"dot\"></div><div class=\"content\"><h3>2025</h3><p>快速发展</p></div></div><div class=\"item\"><div class=\"dot\"></div><div class=\"content\"><h3>2026</h3><p>取得成功</p></div></div></div>",
    "css": "body{margin:0;background:#0d0d0d;display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif}#timeline{position:relative;padding:20px}#timeline::before{content:'';position:absolute;left:29px;top:0;bottom:0;width:2px;background:#333}.item{position:relative;display:flex;align-items:flex-start;margin-bottom:40px;opacity:0;transform:translateX(-20px);animation:slideIn 0.5s forwards}.item:nth-child(1){animation-delay:0.2s}.item:nth-child(2){animation-delay:0.4s}.item:nth-child(3){animation-delay:0.6s}@keyframes slideIn{to{opacity:1;transform:translateX(0)}}.dot{width:20px;height:20px;background:#667eea;border-radius:50%;margin-right:20px;flex-shrink:0;border:4px solid #0d0d0d;z-index:1}.content{background:#1a1a2e;padding:15px 20px;border-radius:8px;min-width:200px}.content h3{color:#667eea;margin:0 0 8px}.content p{color:#aaa;margin:0}",
