  {
    "id": "volume-slider",
    "title": "音量滑块",
    "description": "自定义样式的音量控制滑块",
    "category": "ui",
    "tags": ["音量", "滑块", "控制"],
    "html": "<div id=\"volume\"><span id=\"icon\">🔊</span><div id=\"bar\"><div id=\"fill\"></div><div id=\"handle\"></div></div><span id=\"value\">80%</span></div>",
    "css": "body{margin:0;background:#0d0d0d;display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif}#volume{display:flex;align-items:center;gap:15px}#icon{font-size:1.5rem}#bar{position:relative;width:200px;height:8px;background:#333;border-radius:4px;cursor:pointer}#fill{position:absolute;left:0;top:0;height:100%;width:80%;background:#667eea;border-radius:4px}#handle{position:absolute;left:80%;top:50%;transform:translate(-50%,-50%);width:20px;height:20px;background:#fff;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,0.3)}#value{color:#fff;min-width:40px}",
    "js": "const bar=document.getElementById('bar');const fill=document.getElementById('fill');const handle=document.getElementById('handle');const value=document.getElementById('value');const icon=document.getElementById('icon');let isDragging=false;function update(e){const rect=bar.getBoundingClientRect();let percent=((e.clientX-rect.left)/rect.width)*100;percent=Math.max(0,Math.min(100,percent));fill.style.width=percent+'%';handle.style.left=percent+'%';value.textContent=Math.round(percent)+'%';if(percent===0)icon.textContent='🔇';else if(percent<30)icon.textContent='🔈';else if(percent<70)icon.textContent='🔉';else icon.textContent='🔊'}bar.addEventListener('mousedown',e=>{isDragging=true;update(e)});document.addEventListener('mousemove',e=>{if(isDragging)update(e)});document.addEventListener('mouseup',()=>isDragging=false);",
    "authorName": "Web Effect Studio",
    "viewCount": 0,
    "likeCount": 0
  },
  {
    "id": "weather-card",
