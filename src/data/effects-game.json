                 ],
        "html":  "\u003cdiv class=\"tooltip-container\"\u003e\u003cbutton\u003e悬停查看提示\u003c/button\u003e\u003cdiv class=\"tooltip\"\u003e这是一个提示信息！\u003c/div\u003e\u003c/div\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.tooltip-container{position:relative;display:inline-block}.tooltip-container button{padding:15px 30px;background:#667eea;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:1rem}.tooltip{position:absolute;bottom:120%;left:50%;transform:translateX(-50%);background:#fff;color:#333;padding:10px 20px;border-radius:8px;white-space:nowrap;opacity:0;visibility:hidden;transition:all 0.3s;font-size:0.9rem}.tooltip::after{content:\u0027\u0027;position:absolute;top:100%;left:50%;transform:translateX(-50%);border:8px solid transparent;border-top-color:#fff}.tooltip-container:hover .tooltip{opacity:1;visibility:visible;bottom:130%}",
        "js":  "",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "water-ripple",
        "title":  "水波纹效果",
        "description":  "点击产生水波纹扩散动画",
        "category":  "animation",
        "tags":  [
                     "水波纹",
                     "点击",
                     "扩散"
                 ],
        "html":  "\u003cdiv class=\"ripple-container\" id=\"ripple-container\"\u003e\u003cspan\u003e点击任意位置\u003c/span\u003e\u003c/div\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.ripple-container{position:relative;width:400px;height:300px;background:#1a1a2e;border-radius:16px;display:flex;align-items:center;justify-content:center;overflow:hidden;cursor:pointer;color:#fff;font-size:1.2rem}.ripple{position:absolute;border-radius:50%;background:rgba(102,126,234,0.6);transform:scale(0);animation:ripple 0.6s linear}@keyframes ripple{to{transform:scale(4);opacity:0}}",
        "js":  "document.getElementById(\u0027ripple-container\u0027).addEventListener(\u0027click\u0027,function(e){const ripple=document.createElement(\u0027span\u0027);ripple.className=\u0027ripple\u0027;const rect=this.getBoundingClientRect();const size=Math.max(rect.width,rect.height);ripple.style.width=ripple.style.height=size+\u0027px\u0027;ripple.style.left=e.clientX-rect.left-size/2+\u0027px\u0027;ripple.style.top=e.clientY-rect.top-size/2+\u0027px\u0027;this.appendChild(ripple);setTimeout(()=\u003eripple.remove(),600)})",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "rating-stars",
        "title":  "星级评分",
        "description":  "可交互的星级评分组件",
        "category":  "ui",
        "tags":  [
                     "评分",
                     "星级",
                     "交互"
                 ],
        "html":  "\u003cdiv class=\"rating\"\u003e\u003cspan data-value=\"5\"\u003e★\u003c/span\u003e\u003cspan data-value=\"4\"\u003e★\u003c/span\u003e\u003cspan data-value=\"3\"\u003e★\u003c/span\u003e\u003cspan data-value=\"2\"\u003e★\u003c/span\u003e\u003cspan data-value=\"1\"\u003e★\u003c/span\u003e\u003c/div\u003e\u003cp id=\"rating-text\"\u003e点击评分\u003c/p\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:sans-serif}.rating{display:flex;flex-direction:row-reverse;gap:10px}.rating span{font-size:3rem;color:#444;cursor:pointer;transition:color 0.2s}.rating span:hover,.rating span:hover~span{color:#ffd700}#rating-text{color:#fff;margin-top:20px;font-size:1.1rem}",
        "js":  "const stars=document.querySelectorAll(\u0027.rating span\u0027),text=document.getElementById(\u0027rating-text\u0027);stars.forEach(star=\u003e{star.addEventListener(\u0027click\u0027,()=\u003e{const value=star.dataset.value;text.textContent=\u0027评分: \u0027+value+\u0027 星\u0027;stars.forEach(s=\u003e{s.style.color=s.dataset.value\u003c=value?\u0027#ffd700\u0027:\u0027#444\u0027})})})",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "bouncing-ball",
        "title":  "弹跳球",
        "description":  "物理模拟的弹跳球动画",
        "category":  "animation",
        "tags":  [
                     "弹跳",
                     "物理",
                     "球"
                 ],
        "html":  "\u003ccanvas id=\"c\"\u003e\u003c/canvas\u003e",
        "css":  "body{margin:0;overflow:hidden;background:#0d0d0d}canvas{display:block}",
        "js":  "const c=document.getElementById(\u0027c\u0027),x=c.getContext(\u00272d\u0027);c.width=window.innerWidth;c.height=window.innerHeight;let ball={x:c.width/2,y:100,vx:5,vy:0,radius:30,gravity:0.5,damping:0.8};function draw(){x.fillStyle=\u0027rgba(13,13,13,0.3)\u0027;x.fillRect(0,0,c.width,c.height);ball.vy+=ball.gravity;ball.x+=ball.vx;ball.y+=ball.vy;if(ball.y+ball.radius\u003ec.height){ball.y=c.height-ball.radius;ball.vy*=-ball.damping}if(ball.x+ball.radius\u003ec.width||ball.x-ball.radius\u003c0)ball.vx*=-1;x.beginPath();x.arc(ball.x,ball.y,ball.radius,0,Math.PI*2);const gradient=x.createRadialGradient(ball.x-10,ball.y-10,0,ball.x,ball.y,ball.radius);gradient.addColorStop(0,\u0027#667eea\u0027);gradient.addColorStop(1,\u0027#764ba2\u0027);x.fillStyle=gradient;x.fill();requestAnimationFrame(draw)}draw()",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "notification-toast",
        "title":  "消息通知",
        "description":  "滑入滑出的消息通知组件",
        "category":  "ui",
        "tags":  [
                     "通知",
                     "Toast",
                     "消息"
