    "js": "const c=document.getElementById(\"c\"),x=c.getContext(\"2d\");let w,h,snow=[];function resize(){w=c.width=window.innerWidth;h=c.height=window.innerHeight};function createSnow(){return{x:Math.random()*w,y:Math.random()*h-h,r:Math.random()*3+1,d:Math.random()*3+1}};for(let i=0;i<200;i++)snow.push(createSnow());function draw(){x.clearRect(0,0,w,h);x.fillStyle=\"rgba(255,255,255,0.8)\";x.beginPath();snow.forEach(s=>{x.moveTo(s.x,s.y);x.arc(s.x,s.y,s.r,0,Math.PI*2)});x.fill();snow.forEach(s=>{s.y+=s.d;s.x+=Math.sin(s.y*0.01)*0.5;if(s.y>h){s.y=-10;s.x=Math.random()*w}s.d=Math.random()*3+1});requestAnimationFrame(draw)};resize();draw();window.addEventListener(\"resize\",resize)",
