        "css":  "body{margin:0;min-height:100vh;background:#1e1e1e;display:flex;align-items:center;justify-content:center;font-family:\u0027Fira Code\u0027,monospace}.editor{background:#252526;padding:40px 60px;border-radius:8px}.code{color:#9cdcfe;font-size:1.5rem}.cursor{display:inline-block;width:3px;height:1.5rem;background:#fff;margin-left:2px;animation:blink 1s step-end infinite;vertical-align:text-bottom}@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}",
