    "html": "<div class=\"wrap\"><div class=\"bar\"><div class=\"fill\" id=\"f1\"></div></div><div class=\"bar\"><div class=\"fill stripe\" id=\"f2\"></div></div><div class=\"circ\"><svg viewBox=\"0 0 100 100\"><circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#333\" stroke-width=\"10\"/><circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#667eea\" stroke-width=\"10\" stroke-dasharray=\"251\" stroke-dashoffset=\"251\" id=\"c1\" stroke-linecap=\"round\" transform=\"rotate(-90 50 50)\"/></svg><span id=\"cpct\">0%</span></div></div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.wrap{display:flex;flex-direction:column;gap:28px;width:360px}.bar{height:20px;background:#222;border-radius:10px;overflow:hidden}.fill{height:100%;border-radius:10px;background:linear-gradient(90deg,#667eea,#764ba2);width:0;transition:width 1s ease}.stripe{background:repeating-linear-gradient(45deg,#f5576c,#f5576c 10px,#f9a825 10px,#f9a825 20px);background-size:28px 100%;animation:stripe 0.5s linear infinite;width:0}.circ{position:relative;width:120px;margin:0 auto}.circ svg{transform:rotate(-90deg)}.circ span{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:bold;font-size:1.2rem}@keyframes stripe{to{background-position:28px 0}}",
