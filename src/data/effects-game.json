        "html":  "\u003ccanvas id=\"c\"\u003e\u003c/canvas\u003e",
        "css":  "body{margin:0;overflow:hidden;background:#0a0a0a}canvas{position:fixed;top:0;left:0}",
        "js":  "const c=document.getElementById(\u0027c\u0027),x=c.getContext(\u00272d\u0027);let w,h,p=[],m={x:null,y:null};function resize(){w=c.width=window.innerWidth;h=c.height=window.innerHeight}function create(){return{x:Math.random()*w,y:Math.random()*h,vx:(Math.random()-0.5)*2,vy:(Math.random()-0.5)*2,size:Math.random()*2+1}};for(let i=0;i\u003c80;i++)p.push(create());function draw(){x.fillStyle=\u0027rgba(10,10,10,0.1)\u0027;x.fillRect(0,0,w,h);p.forEach((a,i)=\u003e{a.x+=a.vx;a.y+=a.vy;if(a.x\u003c0||a.x\u003ew)a.vx*=-1;if(a.y\u003c0||a.y\u003eh)a.vy*=-1;x.fillStyle=\u0027rgba(100,200,255,0.6)\u0027;x.beginPath();x.arc(a.x,a.y,a.size,0,Math.PI*2);x.fill();p.slice(i+1).forEach(b=\u003e{const dx=a.x-b.x,dy=a.y-b.y,d=Math.sqrt(dx*dx+dy*dy);if(d\u003c150){x.strokeStyle=\u0027rgba(100,200,255,\u0027+(1-d/150)*0.3+\u0027)\u0027;x.lineWidth=1;x.beginPath();x.moveTo(a.x,a.y);x.lineTo(b.x,b.y);x.stroke()}});if(m.x){const dx=a.x-m.x,dy=a.y-m.y,d=Math.sqrt(dx*dx+dy*dy);if(d\u003c200){x.strokeStyle=\u0027rgba(255,100,100,\u0027+(1-d/200)*0.5+\u0027)\u0027;x.beginPath();x.moveTo(a.x,a.y);x.lineTo(m.x,m.y);x.stroke()}}});requestAnimationFrame(draw)}window.addEventListener(\u0027resize\u0027,resize);window.addEventListener(\u0027mousemove\u0027,e=\u003e{m.x=e.clientX;m.y=e.clientY});window.addEventListener(\u0027mouseout\u0027,()=\u003e{m.x=m.y=null});resize();draw()",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
