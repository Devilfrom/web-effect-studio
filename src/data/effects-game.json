    "html": "<div class=\"shapes\"><div class=\"shape s1\"></div><div class=\"shape s2\"></div><div class=\"shape s3\"></div><div class=\"shape s4\"></div><h1>浮动效果</h1></div>",
    "authorName": "Web Effect Studio",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.shapes{position:relative;width:100%;height:100vh}.shape{position:absolute;opacity:0.3;animation:float 10s ease-in-out infinite}.s1{width:150px;height:150px;background:#667eea;border-radius:30% 70% 70% 30% / 30% 30% 70% 70%;top:10%;left:10%;animation-delay:0s}.s2{width:100px;height:100px;background:#f5576c;border-radius:50%;top:60%;right:15%;animation-delay:-2s}.s3{width:80px;height:80px;background:#4CAF50;transform:rotate(45deg);bottom:20%;left:20%;animation-delay:-4s}.s4{width:120px;height:120px;background:#ff9f43;border-radius:60% 40% 30% 70% / 60% 30% 70% 40%;top:30%;right:25%;animation-delay:-6s}.shapes h1{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:#fff;font-size:3rem;z-index:10}@keyframes float{0%,100%{transform:translate(0,0) rotate(0deg)}25%{transform:translate(20px,-20px) rotate(5deg)}50%{transform:translate(-10px,15px) rotate(-3deg)}75%{transform:translate(15px,10px) rotate(2deg)}}",
    "title": "浮动形状"
  },
  {
    "js": "const c=document.getElementById(\"c\"),x=c.getContext(\"2d\");let w,h,trail=[];function resize(){w=c.width=window.innerWidth;h=c.height=window.innerHeight};function addTrail(e){trail.push({x:e.clientX,y:e.clientY,size:20,alpha:1});if(trail.length>50)trail.shift()}function draw(){x.fillStyle=\"rgba(10,10,10,0.2)\";x.fillRect(0,0,w,h);trail.forEach((t,i)=>{t.size*=0.95;t.alpha*=0.95;if(t.alpha<0.01)trail.splice(i,1);x.beginPath();x.arc(t.x,t.y,t.size,0,Math.PI*2);x.fillStyle=\rgba(102,126,234,);x.fill()});requestAnimationFrame(draw)};window.addEventListener(\"resize\",resize);window.addEventListener(\"mousemove\",addTrail);resize();draw()",
