    "js": "const c=document.getElementById(\"c\"),x=c.getContext(\"2d\");let w,h,particles=[],mouse={x:null,y:null,r:100};const txt=\"WEB EFFECT\";function resize(){w=c.width=window.innerWidth;h=c.height=window.innerHeight;init()};function init(){particles=[];x.font=\"bold 80px sans-serif\";x.textAlign=\"center\";x.textBaseline=\"middle\";const metrics=x.measureText(txt),fw=metrics.width,fh=80;x.fillStyle=\"#fff\";x.fillText(txt,w/2,h/2);const idata=x.getImageData(0,0,w,h),buffer32=new Uint32Array(idata.data.buffer);for(let y=0;y<h;y+=4){for(let x=0;x<w;x+=4){if(buffer32[y*w+x]){const angle=Math.random()*Math.PI*2,speed=Math.random()*2+0.5;particles.push({ox:x,oy:y,x:x,y:y,vx:Math.cos(angle)*speed,vy:Math.sin(angle)*speed,friction:0.95,alpha:1})}}}x.clearRect(0,0,w,h)}function tick(){x.fillStyle=\"rgba(10,10,10,0.1)\";x.fillRect(0,0,w,h);particles.forEach(p=>{if(mouse.x!==null){const dx=mouse.x-p.x,dy=mouse.y-p.y,d=Math.sqrt(dx*dx+dy*dy);if(d<mouse.r){const force=(mouse.r-d)/mouse.r,fx=dx/d*force*0.5,fy=dy/d*force*0.5;p.vx+=fx;p.vy+=fy}}p.vx*=p.friction;p.vy*=p.friction;p.x+=p.vx;p.y+=p.vy;p.alpha=Math.min(p.alpha+0.02,1);x.fillStyle=\rgba(100,200,255,);x.fillRect(p.x,p.y,2,2)});requestAnimationFrame(tick)};window.addEventListener(\"resize\",resize);window.addEventListener(\"mousemove\",e=>{mouse.x=e.clientX;mouse.y=e.clientY});window.addEventListener(\"mouseout\",()=>{mouse.x=mouse.y=null});resize();tick()",
