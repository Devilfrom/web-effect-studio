        "html":  "\u003cul class=\"sortable\"\u003e\u003cli draggable=\"true\"\u003e项目 1\u003c/li\u003e\u003cli draggable=\"true\"\u003e项目 2\u003c/li\u003e\u003cli draggable=\"true\"\u003e项目 3\u003c/li\u003e\u003cli draggable=\"true\"\u003e项目 4\u003c/li\u003e\u003c/ul\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.sortable{list-style:none;padding:0;margin:0;width:300px}.sortable li{padding:20px;margin:10px 0;background:#1a1a2e;border-radius:8px;color:#fff;cursor:move;transition:all 0.2s}.sortable li.dragging{opacity:0.5;transform:scale(1.02)}.sortable li.over{border:2px dashed #667eea}",
        "js":  "const list=document.querySelector(\u0027.sortable\u0027);let dragged=null;list.addEventListener(\u0027dragstart\u0027,e=\u003e{dragged=e.target;e.target.classList.add(\u0027dragging\u0027)});list.addEventListener(\u0027dragend\u0027,e=\u003ee.target.classList.remove(\u0027dragging\u0027));list.addEventListener(\u0027dragover\u0027,e=\u003e{e.preventDefault();const after=getAfter(list,e.clientY);if(after)list.insertBefore(dragged,after);else list.appendChild(dragged)});function getAfter(container,y){return [...container.querySelectorAll(\u0027li:not(.dragging)\u0027)].reduce((closest,child)=\u003e{const box=child.getBoundingClientRect();const offset=y-box.top-box.height/2;if(offset\u003c0\u0026\u0026offset\u003eclosest.offset)return{offset,element:child};return closest},{offset:Number.NEGATIVE_INFINITY}).element}",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "circular-menu",
