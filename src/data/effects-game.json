    {
        "id":  "parallax-scroll",
        "title":  "视差滚动",
        "description":  "多层背景以不同速度滚动产生视差",
        "category":  "animation",
        "tags":  [
                     "视差",
                     "滚动",
                     "背景"
                 ],
        "html":  "\u003cdiv class=\"parallax\"\u003e\u003cdiv class=\"layer layer1\"\u003e\u003c/div\u003e\u003cdiv class=\"layer layer2\"\u003e\u003c/div\u003e\u003cdiv class=\"layer layer3\"\u003e\u003c/div\u003e\u003cdiv class=\"content\"\u003e滚动查看效果\u003c/div\u003e\u003c/div\u003e",
        "css":  "body{margin:0;height:200vh;background:#0d0d0d}.parallax{position:relative;height:100vh;overflow:hidden}.layer{position:absolute;width:120%;height:120%;left:-10%;top:-10%}.layer1{background:linear-gradient(180deg,#1a1a2e 0%,#16213e 100%);transform:translateZ(-2px) scale(3)}.layer2{background:radial-gradient(circle at 30% 30%,rgba(102,126,234,0.3) 0%,transparent 50%);transform:translateZ(-1px) scale(2)}.layer3{background:radial-gradient(circle at 70% 70%,rgba(245,87,108,0.3) 0%,transparent 50%)}.content{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);color:#fff;font-size:3rem;font-family:sans-serif;text-align:center}",
        "js":  "window.addEventListener(\u0027scroll\u0027,()=\u003e{const scrolled=window.pageYOffset;document.querySelectorAll(\u0027.layer\u0027).forEach((layer,i)=\u003e{const speed=(i+1)*0.5;layer.style.transform=\u0027translateY(\u0027+scrolled*speed+\u0027px)\u0027})})",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "countdown-timer",
        "title":  "倒计时器",
        "description":  "带翻页效果的倒计时组件",
        "category":  "ui",
        "tags":  [
                     "倒计时",
                     "计时器",
                     "组件"
                 ],
        "html":  "\u003cdiv class=\"countdown\"\u003e\u003cdiv class=\"unit\"\u003e\u003cspan id=\"h\"\u003e00\u003c/span\u003e\u003clabel\u003e时\u003c/label\u003e\u003c/div\u003e\u003cdiv class=\"unit\"\u003e\u003cspan id=\"m\"\u003e00\u003c/span\u003e\u003clabel\u003e分\u003c/label\u003e\u003c/div\u003e\u003cdiv class=\"unit\"\u003e\u003cspan id=\"s\"\u003e00\u003c/span\u003e\u003clabel\u003e秒\u003c/label\u003e\u003c/div\u003e\u003c/div\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.countdown{display:flex;gap:20px}.unit{text-align:center;background:#1a1a2e;padding:30px 40px;border-radius:16px;min-width:100px}.unit span{display:block;font-size:4rem;font-weight:bold;color:#667eea;font-variant-numeric:tabular-nums}.unit label{display:block;margin-top:10px;color:#888;font-size:1rem}",
        "js":  "function update(){const now=new Date();const end=new Date(now.getFullYear(),now.getMonth(),now.getDate()+1);const diff=end-now;const h=Math.floor(diff/3600000);const m=Math.floor((diff%3600000)/60000);const s=Math.floor((diff%60000)/1000);document.getElementById(\u0027h\u0027).textContent=String(h).padStart(2,\u00270\u0027);document.getElementById(\u0027m\u0027).textContent=String(m).padStart(2,\u00270\u0027);document.getElementById(\u0027s\u0027).textContent=String(s).padStart(2,\u00270\u0027)};setInterval(update,1000);update()",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "image-comparison",
        "title":  "图片对比",
        "description":  "拖拽滑块对比两张图片",
        "category":  "ui",
        "tags":  [
                     "图片",
                     "对比",
                     "滑块"
                 ],
        "html":  "\u003cdiv class=\"compare\" id=\"compare\"\u003e\u003cdiv class=\"before\"\u003e\u003c/div\u003e\u003cdiv class=\"after\"\u003e\u003c/div\u003e\u003cdiv class=\"slider\"\u003e\u003c/div\u003e\u003c/div\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center}.compare{position:relative;width:600px;height:400px;overflow:hidden;border-radius:12px;cursor:ew-resize}.before,.after{position:absolute;inset:0}.before{background:linear-gradient(135deg,#667eea,#764ba2)}.after{background:linear-gradient(135deg,#f093fb,#f5576c);width:50%}.slider{position:absolute;top:0;bottom:0;left:50%;width:4px;background:#fff;transform:translateX(-50%);box-shadow:0 0 10px rgba(0,0,0,0.5)}",
        "js":  "const c=document.getElementById(\u0027compare\u0027),after=c.querySelector(\u0027.after\u0027),slider=c.querySelector(\u0027.slider\u0027);let isDragging=false;c.addEventListener(\u0027mousedown\u0027,()=\u003eisDragging=true);window.addEventListener(\u0027mouseup\u0027,()=\u003eisDragging=false);c.addEventListener(\u0027mousemove\u0027,e=\u003e{if(!isDragging)return;const rect=c.getBoundingClientRect();const x=Math.max(0,Math.min(1,(e.clientX-rect.left)/rect.width));after.style.width=x*100+\u0027%\u0027;slider.style.left=x*100+\u0027%\u0027})",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "audio-visualizer",
        "title":  "音频可视化",
        "description":  "Canvas 音频频谱可视化效果",
        "category":  "animation",
        "tags":  [
                     "音频",
                     "可视化",
                     "Canvas"
                 ],
        "html":  "\u003ccanvas id=\"c\"\u003e\u003c/canvas\u003e\u003cp\u003e点击开始模拟\u003c/p\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:sans-serif;color:#888}canvas{border-radius:12px}",
        "js":  "const c=document.getElementById(\u0027c\u0027),x=c.getContext(\u00272d\u0027);c.width=600;c.height=200;let bars=Array(64).fill(0),t=0;function animate(){x.fillStyle=\u0027#0d0d0d\u0027;x.fillRect(0,0,c.width,c.height);bars=bars.map((v,i)=\u003e{const target=Math.random()*150+20;return v+(target-v)*0.1});const bw=c.width/bars.length;bars.forEach((h,i)=\u003e{const hue=(i/bars.length)*360;x.fillStyle=\u0027hsl(\u0027+hue+\u0027,70%,50%)\u0027;x.fillRect(i*bw,c.height-h,bw-2,h)});requestAnimationFrame(animate)}document.addEventListener(\u0027click\u0027,animate);animate()",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "magnetic-button",
        "title":  "磁性按钮",
        "description":  "按钮被鼠标吸引的磁性效果",
        "category":  "ui",
        "tags":  [
                     "按钮",
                     "磁性",
                     "互动"
                 ],
        "html":  "\u003cbutton class=\"magnetic\"\u003e磁性按钮\u003c/button\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.magnetic{padding:24px 48px;font-size:1.2rem;color:#fff;background:#667eea;border:none;border-radius:12px;cursor:pointer;transition:transform 0.2s ease}",
        "js":  "const btn=document.querySelector(\u0027.magnetic\u0027);document.addEventListener(\u0027mousemove\u0027,e=\u003e{const rect=btn.getBoundingClientRect();const x=e.clientX-(rect.left+rect.width/2);const y=e.clientY-(rect.top+rect.height/2);const dist=Math.sqrt(x*x+y*y);if(dist\u003c150){const strength=(150-dist)/150;btn.style.transform=\u0027translate(\u0027+x*strength*0.3+\u0027px,\u0027+y*strength*0.3+\u0027px)\u0027}else{btn.style.transform=\u0027translate(0,0)\u0027}})",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "text-scramble",
        "title":  "文字打乱",
        "description":  "文字随机打乱后重组的特效",
        "category":  "text",
        "tags":  [
                     "文字",
                     "打乱",
                     "动画"
                 ],
        "html":  "\u003cdiv class=\"text\" data-value=\"HELLO WORLD\"\u003eHELLO WORLD\u003c/div\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:monospace}.text{font-size:3rem;color:#0f0;cursor:pointer}",
        "js":  "const el=document.querySelector(\u0027.text\u0027);const chars=\u0027ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789\u0027;let interval=null;el.addEventListener(\u0027mouseenter\u0027,()=\u003e{let iteration=0;clearInterval(interval);interval=setInterval(()=\u003e{el.innerText=el.dataset.value.split(\u0027\u0027).map((letter,index)=\u003e{if(index\u003citeration)return el.dataset.value[index];return chars[Math.floor(Math.random()*chars.length)]}).join(\u0027\u0027);if(iteration\u003e=el.dataset.value.length)clearInterval(interval);iteration+=1/3},30)})",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "fireworks-canvas",
        "title":  "烟花效果",
        "description":  "Canvas 烟花绽放动画",
        "category":  "animation",
        "tags":  [
                     "烟花",
                     "Canvas",
                     "粒子"
                 ],
        "html":  "\u003ccanvas id=\"c\"\u003e\u003c/canvas\u003e\u003cp\u003e点击发射烟花\u003c/p\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:sans-serif;color:#888}canvas{position:fixed;top:0;left:0}",
        "js":  "const c=document.getElementById(\u0027c\u0027),x=c.getContext(\u00272d\u0027);c.width=window.innerWidth;c.height=window.innerHeight;let fireworks=[],particles=[];class Firework{constructor(tx,ty){this.x=c.width/2;this.y=c.height;this.tx=tx;this.ty=ty;this.speed=3;this.angle=Math.atan2(ty-c.height,tx-c.width/2);this.vx=Math.cos(this.angle)*this.speed;this.vy=Math.sin(this.angle)*this.speed;this.hue=Math.random()*360}update(){this.x+=this.vx;this.y+=this.vy;if(Math.abs(this.x-this.tx)\u003c10\u0026\u0026Math.abs(this.y-this.ty)\u003c10){for(let i=0;i\u003c50;i++)particles.push(new Particle(this.x,this.y,this.hue));return true}return false}draw(){x.fillStyle=\u0027hsl(\u0027+this.hue+\u0027,100%,50%)\u0027;x.beginPath();x.arc(this.x,this.y,3,0,Math.PI*2);x.fill()}}class Particle{constructor(x,y,hue){this.x=x;this.y=y;this.hue=hue;this.angle=Math.random()*Math.PI*2;this.speed=Math.random()*5+2;this.vx=Math.cos(this.angle)*this.speed;this.vy=Math.sin(this.angle)*this.speed;this.alpha=1;this.decay=Math.random()*0.02+0.01}update(){this.x+=this.vx;this.y+=this.vy;this.vy+=0.1;this.alpha-=this.decay;return this.alpha\u003c=0}draw(){x.fillStyle=\u0027hsla(\u0027+this.hue+\u0027,100%,50%,\u0027+this.alpha+\u0027)\u0027;x.beginPath();x.arc(this.x,this.y,2,0,Math.PI*2);x.fill()}}function animate(){x.fillStyle=\u0027rgba(0,0,0,0.1)\u0027;x.fillRect(0,0,c.width,c.height);fireworks=fireworks.filter(fw=\u003e{fw.draw();return !fw.update()});particles=particles.filter(p=\u003e{p.draw();return !p.update()});requestAnimationFrame(animate)}c.addEventListener(\u0027click\u0027,e=\u003efireworks.push(new Firework(e.clientX,e.clientY)));animate()",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "infinite-scroll",
        "title":  "无限滚动",
        "description":  "无缝循环滚动的内容列表",
        "category":  "ui",
        "tags":  [
                     "滚动",
                     "无限",
                     "列表"
                 ],
        "html":  "\u003cdiv class=\"scroll-container\"\u003e\u003cdiv class=\"scroll-content\"\u003e\u003cdiv class=\"item\"\u003eItem 1\u003c/div\u003e\u003cdiv class=\"item\"\u003eItem 2\u003c/div\u003e\u003cdiv class=\"item\"\u003eItem 3\u003c/div\u003e\u003cdiv class=\"item\"\u003eItem 4\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e",
