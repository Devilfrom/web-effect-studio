    "html": "<canvas id=\"c\"></canvas><div id=\"msg\" class=\"hidden\">游戏结束！<button id=\"replay\">再来一局</button></div>",
    "css": "body{margin:0;background:#111;display:flex;align-items:center;justify-content:center;min-height:100vh}canvas{display:block;border-radius:4px}#msg{position:absolute;text-align:center}",
    "js": "const c=document.getElementById(\"c\"),x=c.getContext(\"2d\");c.width=500;c.height=500;let bx,by,bvx,bvy,paddle,pads,alive;const PW=80,PH=12,BALL=8;const COLS=8,ROWS=5,colors=[\"#f44\",\"#f80\",\"#ff0\",\"#0f0\",\"#0cf\"];function init(){paddle={x:210,y:460,w:PW};bx=250;by=400;bvx=3*(Math.random()>0.5?1:-1);bvy=-3;alive=true;pads=[];for(let r=0;r<ROWS;r++)for(let col=0;col<COLS;col++)pads.push({x:col*60+10,y:r*25+40,w:55,h:18,color:colors[r]});tick()};function tick(){x.fillStyle=\"#1a1a1a\";x.fillRect(0,0,500,500);pads.forEach(p=>{x.fillStyle=p.color;x.fillRect(p.x,p.y,p.w,p.h)});x.fillStyle=\"#fff\";x.fillRect(paddle.x,paddle.y,paddle.w,PH);x.beginPath();x.arc(bx,by,BALL,0,Math.PI*2);x.fill();bx+=bvx;by+=bvy;if(bx<8||bx>492)bvx*=-1;if(by<8)bvy*=-1;if(bx>paddle.x&&bx<paddle.x+PW&&by>460&&by<470)bvy=-Math.abs(bvy);pads=pads.filter(p=>{if(bx>p.x&&bx<p.x+p.w&&by>p.y&&by<p.y+p.h){bvy*=-1;return false}return true});if(pads.length===0||by>492){alive=false;document.getElementById(\"msg\").classList.remove(\"hidden\");return}requestAnimationFrame(tick)};document.addEventListener(\"mousemove\",e=>{const r=c.getBoundingClientRect();paddle.x=Math.max(0,Math.min(500-PW,e.clientX-r.left-PW/2))});document.addEventListener(\"keydown\",e=>{if(e.key===\"ArrowLeft\")paddle.x=Math.max(0,paddle.x-15);if(e.key===\"ArrowRight\")paddle.x=Math.min(500-PW,paddle.x+15)});document.getElementById(\"replay\").addEventListener(\"click\",()=>{document.getElementById(\"msg\").classList.add(\"hidden\");init()});init();",
    "authorName": "Web Effect Studio",
    "viewCount": 2600,
    "likeCount": 198
  },
  {
    "id": "sudoku-game",
    "title": "数独游戏",
    "description": "经典9x9数独，点击格子填入数字",
    "category": "game",
    "tags": [
      "游戏",
      "数独",
      "益智"
    ],
    "html": "<div id=\"wrap\"><div id=\"board\"></div><div id=\"pad\">123456789<span id=\"del\">x</span></div><div id=\"win\" class=\"hidden\">通关成功！</div></div>",
    "css": "body{margin:0;background:#1a1a2e;display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif}#wrap{text-align:center}#board{display:grid;grid-template-columns:repeat(9,38px);gap:1px;background:#333;padding:4px;border:2px solid #667}#board div{background:#fff;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:bold;cursor:pointer;transition:background 0.1s}#board div.fixed{background:#eee;color:#000}#board div.selected{background:#bce}#pad{display:flex;gap:4px;margin-top:12px;justify-content:center;flex-wrap:wrap;max-width:360px}#pad span,#del{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;background:#667eea;color:#fff;border-radius:6px;cursor:pointer;font-size:1.1rem;font-weight:bold}#del{background:#f5576c;width:60px}",
    "js": "const board=document.getElementById(\"board\");const PUZ=[[5,3,0,0,7,0,0,0,0],[6,0,0,1,9,5,0,0,0],[0,9,8,0,0,0,0,6,0],[8,0,0,0,6,0,0,0,3],[4,0,0,8,0,3,0,0,1],[7,0,0,0,2,0,0,0,6],[0,6,0,0,0,0,2,8,0],[0,0,0,4,1,9,0,0,5],[0,0,0,0,8,0,0,7,9]];let sol=PUZ.map(r=>[...r]),sel=null;function solve(g){const r=g.findIndex(row=>row.includes(0));if(r===-1)return true;for(let n=1;n<=9;n++){if(g[r].every((v,c)=>v!==n&&!g.some(row=>row[c]===n))){g[r][g[r].indexOf(0)]=n;if(solve(g))return true;g[r][g[r].indexOf(n)]=0}}return false};solve(sol);function render(){board.innerHTML=\"\";PUZ.forEach((row,ri)=>row.forEach((v,ci)=>{const d=document.createElement(\"div\");d.textContent=v||\"\";if(v)d.className=\"fixed\";d.onclick=()=>{document.querySelectorAll(\"#board div\").forEach(x=>x.classList.remove(\"selected\"));d.classList.add(\"selected\");sel={ri,ci}}});board.appendChild(d)}))};document.querySelectorAll(\"#pad span\").forEach(b=>{b.onclick=()=>{if(!sel)return;const [ri,ci]=sel;if(PUZ[ri][ci])return;PUZ[ri][ci]=+b.textContent;render();if(PUZ.every(r=>r.every(v=>v)))document.getElementById(\"win\").classList.remove(\"hidden\")}});document.getElementById(\"del\").onclick=()=>{if(!sel)return;PUZ[sel[0]][sel[1]]=0;render()};render();",
    "authorName": "Web Effect Studio",
    "viewCount": 1800,
    "likeCount": 156
  },
  {
    "id": "animated-btn",
    "title": "创意按钮合集",
    "description": "悬停动效按钮：填充/波纹/光扫/弹跳/箭头动画",
    "category": "ui",
