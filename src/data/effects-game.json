      "UI"
    ],
    "html": "<div class=\"btns\"><button id=\"open1\">居中弹窗</button><button id=\"open2\">通知消息</button><button id=\"open3\">确认对话框</button></div><div id=\"modal1\" class=\"modal\"><div class=\"modal-body\"><h2>欢迎回来！</h2><p>Web Effect Studio 让前端开发更有趣</p><button id=\"close1\">关闭</button></div></div><div id=\"notif\" class=\"notif hidden\">有新消息通知</div>",
    "css": "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;gap:16px;font-family:sans-serif;flex-wrap:wrap}button{padding:12px 24px;background:#667eea;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:1rem;transition:opacity 0.2s}button:hover{opacity:0.8}.modal{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.3s;z-index:100}.modal.show{opacity:1;pointer-events:all}.modal-body{background:#1a1a2e;border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:32px;max-width:360px;text-align:center;transform:scale(0.9);transition:transform 0.3s}.modal.show .modal-body{transform:scale(1)}.modal-body h2{color:#fff;margin:0 0 12px}.modal-body p{color:#aaa;margin:0 0 20px}.notif{position:fixed;top:20px;right:20px;background:#4CAF50;color:#fff;padding:14px 24px;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,0.3);font-family:sans-serif;z-index:200;transform:translateX(calc(100% + 40px));transition:transform 0.3s cubic-bezier(0.68,-0.55,0.27,1.55)}.notif.show{transform:translateX(0)}",
    "js": "document.getElementById(\"open1\").onclick=()=>document.getElementById(\"modal1\").classList.add(\"show\");document.getElementById(\"close1\").onclick=()=>document.getElementById(\"modal1\").classList.remove(\"show\");document.getElementById(\"modal1\").onclick=e=>{if(e.target===document.getElementById(\"modal1\"))document.getElementById(\"modal1\").classList.remove(\"show\")};document.getElementById(\"open2\").onclick=()=>{const n=document.getElementById(\"notif\");n.classList.add(\"show\");setTimeout(()=>n.classList.remove(\"show\"),3000)};document.getElementById(\"open3\").onclick=()=>{const r=confirm(\"确认执行此操作？\");if(r){const n=document.getElementById(\"notif\");n.textContent=\"操作已确认！\";n.classList.add(\"show\");setTimeout(()=>n.classList.remove(\"show\"),3000)}};",
