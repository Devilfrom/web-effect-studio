    {
        "id":  "clock-analog",
        "title":  "模拟时钟",
        "description":  "Canvas 绘制的模拟时钟，实时显示当前时间",
        "category":  "ui",
        "tags":  [
                     "时钟",
                     "Canvas",
                     "实时"
                 ],
        "html":  "\u003ccanvas id=\"clock\" width=\"300\" height=\"300\"\u003e\u003c/canvas\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center}canvas{background:#1a1a2e;border-radius:50%;box-shadow:0 0 50px rgba(102,126,234,0.3)}",
        "js":  "const c=document.getElementById(\u0027clock\u0027),x=c.getContext(\u00272d\u0027),r=150;function draw(){x.clearRect(0,0,300,300);const now=new Date(),h=now.getHours(),m=now.getMinutes(),s=now.getSeconds();x.strokeStyle=\u0027#667eea\u0027;x.lineWidth=2;x.beginPath();x.arc(r,r,140,0,Math.PI*2);x.stroke();for(let i=0;i\u003c12;i++){const a=(i*30-90)*Math.PI/180;x.beginPath();x.moveTo(r+120*Math.cos(a),r+120*Math.sin(a));x.lineTo(r+135*Math.cos(a),r+135*Math.sin(a));x.stroke()}x.lineWidth=4;x.strokeStyle=\u0027#fff\u0027;const ha=((h%12)*30+m*0.5-90)*Math.PI/180;x.beginPath();x.moveTo(r,r);x.lineTo(r+80*Math.cos(ha),r+80*Math.sin(ha));x.stroke();x.lineWidth=3;const ma=(m*6-90)*Math.PI/180;x.beginPath();x.moveTo(r,r);x.lineTo(r+110*Math.cos(ma),r+110*Math.sin(ma));x.stroke();x.strokeStyle=\u0027#f5576c\u0027;x.lineWidth=2;const sa=(s*6-90)*Math.PI/180;x.beginPath();x.moveTo(r,r);x.lineTo(r+130*Math.cos(sa),r+130*Math.sin(sa));x.stroke();requestAnimationFrame(draw)}draw()",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "matrix-rain",
        "title":  "矩阵雨",
        "description":  "黑客帝国风格的矩阵代码雨效果",
        "category":  "animation",
        "tags":  [
                     "矩阵",
                     "代码雨",
                     "黑客帝国"
                 ],
        "html":  "\u003ccanvas id=\"c\"\u003e\u003c/canvas\u003e",
        "css":  "body{margin:0;overflow:hidden;background:#000}canvas{position:fixed;top:0;left:0}",
        "js":  "const c=document.getElementById(\u0027c\u0027),x=c.getContext(\u00272d\u0027);c.width=window.innerWidth;c.height=window.innerHeight;const chars=\u0027ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^\u0026*\u0027,fontSize=14,columns=c.width/fontSize,drops=[];for(let i=0;i\u003ccolumns;i++)drops[i]=Math.random()*-100;x.fillStyle=\u0027#0f0\u0027;x.font=fontSize+\u0027px monospace\u0027;function draw(){x.fillStyle=\u0027rgba(0,0,0,0.05)\u0027;x.fillRect(0,0,c.width,c.height);x.fillStyle=\u0027#0f0\u0027;for(let i=0;i\u003cdrops.length;i++){const text=chars[Math.floor(Math.random()*chars.length)];x.fillText(text,i*fontSize,drops[i]*fontSize);if(drops[i]*fontSize\u003ec.height\u0026\u0026Math.random()\u003e0.975)drops[i]=0;drops[i]++}requestAnimationFrame(draw)}draw()",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
    {
        "id":  "gradient-border-card",
        "title":  "渐变边框卡片",
