    {
        "id":  "scroll-reveal",
        "title":  "滚动显示",
        "description":  "元素随滚动逐渐显示动画",
        "category":  "animation",
        "tags":  [
                     "滚动",
                     "显示",
                     "动画"
                 ],
        "html":  "\u003cdiv class=\"container\"\u003e\u003cdiv class=\"box\"\u003e向下滚动\u003c/div\u003e\u003cdiv class=\"box reveal\"\u003e我会淡入\u003c/div\u003e\u003cdiv class=\"box reveal\"\u003e我也会\u003c/div\u003e\u003cdiv class=\"box reveal\"\u003e还有我\u003c/div\u003e\u003c/div\u003e",
        "css":  "body{margin:0;background:#0d0d0d;font-family:sans-serif}.container{padding:100px 20px;max-width:600px;margin:0 auto}.box{padding:60px;margin:40px 0;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:16px;color:#fff;text-align:center;font-size:1.5rem;opacity:0;transform:translateY(50px);transition:all 0.6s ease}.box.visible{opacity:1;transform:translateY(0)}",
        "js":  "const boxes=document.querySelectorAll(\u0027.reveal\u0027);const observer=new IntersectionObserver((entries)=\u003e{entries.forEach(entry=\u003e{if(entry.isIntersecting)entry.target.classList.add(\u0027visible\u0027)})},{threshold:0.3});boxes.forEach(box=\u003eobserver.observe(box))",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
