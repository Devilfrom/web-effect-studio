        "html":  "\u003cdiv class=\"spotlight\"\u003e\u003ch1\u003e聚光灯效果\u003c/h1\u003e\u003cp\u003e移动鼠标查看效果\u003c/p\u003e\u003c/div\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#000;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.spotlight{position:relative;padding:100px;text-align:center;color:#fff;background:radial-gradient(circle at var(--x,50%) var(--y,50%),transparent 0%,rgba(0,0,0,0.95) 200px)}.spotlight h1{font-size:3rem;margin:0 0 20px}.spotlight p{color:#888}",
        "js":  "const spot=document.querySelector(\u0027.spotlight\u0027);document.addEventListener(\u0027mousemove\u0027,e=\u003e{const rect=spot.getBoundingClientRect();const x=((e.clientX-rect.left)/rect.width)*100;const y=((e.clientY-rect.top)/rect.height)*100;spot.style.setProperty(\u0027--x\u0027,x+\u0027%\u0027);spot.style.setProperty(\u0027--y\u0027,y+\u0027%\u0027)})",
