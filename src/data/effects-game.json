    "html": "<canvas id=\"c\"></canvas><div id=\"over\" class=\"hidden\"><span id=\"final\">0</span><br><button id=\"restart\">再试一次</button></div>",
    "css": "body{margin:0;background:#87CEEB;display:flex;align-items:center;justify-content:center;min-height:100vh}canvas{display:block;border-radius:8px}#over{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(0,0,0,0.6);border-radius:8px}#over.hidden{display:none}#over span{font-size:4rem;color:#fff;font-weight:bold}#restart{margin-top:16px;padding:8px 24px;background:#4CAF50;color:#fff;border:none;border-radius:6px;cursor:pointer}",
    "js": "const c=document.getElementById(\"c\"),x=c.getContext(\"2d\");c.width=400;c.height=600;let bird={y:300,v:0},pipes=[],score=0,alive=true,gf=0;const G=0.4,FLY=-7,PW=50,GAP=150;function init(){bird={y:300,v:0};pipes=[];score=0;alive=true;gf=0;document.getElementById(\"over\").classList.add(\"hidden\");tick()};function addPipe(){const h=Math.random()*200+100;pipes.push({x:400,h,passed:false})};function tick(){if(!alive)return;gf++;bird.v+=G;bird.y+=bird.v;if(gf%90===0)addPipe();pipes.forEach(p=>p.x-=3);if(pipes[0]&&pipes[0].x<-PW)pipes.shift();pipes.forEach(p=>{if(!p.passed&&bird.y>0&&bird.y<600){if(p.x<230&&p.x>PW){score++;p.passed=true}}if(p.x<230&&p.x>PW&&(bird.y<p.h||bird.y>p.h+GAP)){alive=false}});if(bird.y>580)alive=false;x.fillStyle=\"#87CEEB\";x.fillRect(0,0,400,600);x.fillStyle=\"#4CAF50\";pipes.forEach(p=>{x.fillRect(p.x,0,PW,p.h);x.fillRect(p.x,p.h+GAP,PW,600)});x.fillStyle=\"#F9A825\";x.beginPath();x.arc(60,bird.y,15,0,Math.PI*2);x.fill();x.fillStyle=\"#fff\";x.beginPath();x.arc(65,bird.y-3,5,0,Math.PI*2);x.fill();x.fillStyle=\"#000\";x.fill();x.fillStyle=\"#fff\";x.font=\"bold 32px sans-serif\";x.textAlign=\"center\";x.fillText(score,200,50);if(!alive){document.getElementById(\"over\").classList.remove(\"hidden\");document.getElementById(\"final\").textContent=score;return}requestAnimationFrame(tick)};c.addEventListener(\"click\",()=>{if(alive)bird.v=FLY});document.getElementById(\"restart\").addEventListener(\"click\",init);tick();",
    "authorName": "Web Effect Studio",
    "viewCount": 4100,
    "likeCount": 356
