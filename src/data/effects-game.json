    "html": "<div class=\"toggles\"><label><input type=\"checkbox\"><span class=\"t t1\"></span>深色模式</label><label><input type=\"checkbox\" checked><span class=\"t t2\"></span>通知推送</label><label><input type=\"checkbox\"><span class=\"t t3\"></span>自动保存</label><label><input type=\"checkbox\" checked><span class=\"t t4\"></span>隐私模式</label></div>",
    "css": "body{margin:0;min-height:100vh;background:#1a1a2e;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;font-family:sans-serif;color:#fff}label{display:flex;align-items:center;gap:12px;cursor:pointer;font-size:1.1rem}input{display:none}.t{position:relative;width:50px;height:26px;border-radius:13px;background:#333;transition:background 0.3s;display:inline-block}.t::after{content:\"\";position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:#fff;transition:transform 0.3s cubic-bezier(0.68,-0.55,0.27,1.55)}input:checked~.t.t1{background:#667eea}input:checked~.t.t1::after{transform:translateX(24px)}input:checked~.t.t2{background:#4CAF50}input:checked~.t.t2::after{transform:translateX(24px)}input:checked~.t.t3{background:#f5576c}input:checked~.t.t3::after{transform:translateX(24px)}input:checked~.t.t4{background:#ff9f43}input:checked~.t.t4::after{transform:translateX(24px)}",
