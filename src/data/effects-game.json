        "html":  "\u003cdiv class=\"menu\"\u003e\u003cbutton class=\"toggle\"\u003e+\u003c/button\u003e\u003cdiv class=\"items\"\u003e\u003cspan\u003e🏠\u003c/span\u003e\u003cspan\u003e🔍\u003c/span\u003e\u003cspan\u003e⚙️\u003c/span\u003e\u003cspan\u003e👤\u003c/span\u003e\u003c/div\u003e\u003c/div\u003e",
        "css":  "body{margin:0;min-height:100vh;background:#0d0d0d;display:flex;align-items:center;justify-content:center;font-family:sans-serif}.menu{position:relative;width:60px;height:60px}.toggle{width:60px;height:60px;border-radius:50%;border:none;background:#667eea;color:#fff;font-size:2rem;cursor:pointer;transition:transform 0.3s;z-index:10;position:relative}.menu.active .toggle{transform:rotate(45deg)}.items{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}.items span{position:absolute;width:50px;height:50px;border-radius:50%;background:#1a1a2e;display:flex;align-items:center;justify-content:center;font-size:1.5rem;cursor:pointer;transition:all 0.3s;opacity:0}.menu.active .items span:nth-child(1){transform:translate(-80px,0);opacity:1}.menu.active .items span:nth-child(2){transform:translate(0,-80px);opacity:1}.menu.active .items span:nth-child(3){transform:translate(80px,0);opacity:1}.menu.active .items span:nth-child(4){transform:translate(0,80px);opacity:1}",
        "js":  "document.querySelector(\u0027.toggle\u0027).addEventListener(\u0027click\u0027,()=\u003edocument.querySelector(\u0027.menu\u0027).classList.toggle(\u0027active\u0027))",
        "authorName":  "Web Effect Studio",
        "viewCount":  0,
        "likeCount":  0
    },
