    {
        "js":  "const c=document.getElementById(\"c\"),x=c.getContext(\"2d\");let w,h,stars=[];function resize(){w=c.width=window.innerWidth;h=c.height=window.innerHeight};function createStar(){return{x:Math.random()*w,y:Math.random()*h,z:Math.random()*2+0.5}};for(let i=0;i\u003c500;i++)stars.push(createStar());function draw(){x.fillStyle=\"#000\";x.fillRect(0,0,w,h);stars.forEach(s=\u003e{s.z-=0.01;if(s.z\u003c=0){s.z=2;s.x=Math.random()*w;s.y=Math.random()*h}const sx=s.x/s.z*100+w/2,sy=s.y/s.z*100+h/2,size=Math.max(0.1,3/s.z);x.fillStyle=\rgba(255,255,255,);x.beginPath();x.arc(sx,sy,size,0,Math.PI*2);x.fill()});requestAnimationFrame(draw)};resize();draw();window.addEventListener(\"resize\",resize)",
