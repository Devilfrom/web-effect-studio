        "css":  "*{margin:0;padding:0;box-sizing:border-box}body{font-family:system-ui,-apple-system,sans-serif;background-color:#0a0a0a;color:#fff;height:100vh;display:flex;align-items:center;justify-content:center}.card-container{padding:2px;border-radius:24px;position:relative;background:linear-gradient(-30deg,#ff6b6b,transparent,#4ecdc4,#45b7d1,#ff6b6b),linear-gradient(30deg,#45b7d1,#96e6a1,#d4fc79,#ff6b6b);background-size:300% 300%;animation:gradient 4s ease infinite}.inner-container{padding:2px;border-radius:22px;overflow:hidden}.border-outer{padding:48px;background:#0a0a0a;border-radius:20px;position:relative}.glow-layer-1,.glow-layer-2{position:absolute;inset:0;border-radius:20px;filter:blur(40px);opacity:0.6}.glow-layer-1{background:linear-gradient(45deg,#ff6b6b,#feca57)}.glow-layer-2{background:linear-gradient(-45deg,#45b7d1,#96e6a1)}.content-container{position:absolute;inset:0;display:flex;flex-direction:column;padding:48px}.scrollbar-glass{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);padding:8px 16px;border-radius:14px;font-weight:bold;text-transform:uppercase;font-size:14px;width:fit-content}.title{font-size:2rem;font-weight:bold;margin-top:16px}.divider{height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);margin:16px 0}.description{color:rgba(255,255,255,0.7);line-height:1.6}@keyframes gradient{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}",
